#!/usr/bin/env python
import os
import sys

# Definir opciones de SCons
opts = Variables()
opts.Add(EnumVariable("platform", "Target platform", sys.platform, allowed_values=["windows", "linux", "macos"]))
opts.Add(EnumVariable("target", "Compilation target", "template_debug", allowed_values=["template_debug", "template_release"]))
opts.Add(BoolVariable("use_mingw", "Use MinGW on Windows", False))
opts.Add(EnumVariable("arch", "Target architecture", "x86_64", allowed_values=["x86_64", "x86", "arm64", "rv64"]))

env = Environment(variables=opts)
opts.Update(env)

# Rutas base
godot_cpp_path = env.get("godot_cpp_path", "godot-cpp")

# Validar directorio de bindings
if not os.path.exists(godot_cpp_path):
    print(f"ATENCION: No se encontró la carpeta de bindings 'godot-cpp'. Configura la ruta correcta o descárgala en godot/godot-cpp.")

# Configurar plataforma
if env["platform"] == "windows":
    if env["use_mingw"]:
        env.Tool("mingw")
    else:
        env.Tool("default")
    env.Append(LIBS=["ws2_32"])  # WinSock2 para sockets TCP
    env.Append(LINKFLAGS=["-static", "-static-libgcc", "-static-libstdc++"])
elif env["platform"] == "linux":
    env.Append(CCFLAGS=["-fPIC"])
elif env["platform"] == "macos":
    env.Append(CCFLAGS=["-arch", "x86_64", "-arch", "arm64"])
    env.Append(LINKFLAGS=["-arch", "x86_64", "-arch", "arm64"])

# Paths de cabeceras de godot-cpp
env.Append(CPPPATH=[
    "src",
    os.path.join(godot_cpp_path, "include"),
    os.path.join(godot_cpp_path, "gdextension"),
    os.path.join(godot_cpp_path, "gen", "include"),
])

# Archivos fuente
sources = Glob("src/*.cpp")

# Nombre de la librería de salida
lib_prefix = "lib"
lib_suffix = f".{env['platform']}.{env['target']}.{env['arch']}"

# Vincular bindings de godot-cpp
env.Append(LIBPATH=[os.path.join(godot_cpp_path, "bin")])
env.Append(LIBS=["godot-cpp" + lib_suffix])

if env["platform"] == "windows":
    lib_ext = ".dll"
elif env["platform"] == "macos":
    lib_ext = ".dylib"
else:
    lib_ext = ".so"

output_name = f"bin/{lib_prefix}blender_bridge{lib_suffix}{lib_ext}"

# Construir librería compartida
shared_lib = env.SharedLibrary(target=output_name, source=sources)
Default(shared_lib)
